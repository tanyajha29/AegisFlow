PROJECT_NAME=Dristi-Scan
ENVIRONMENT=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/drishtiscan
SECRET_KEY=replace-with-a-long-random-secret
# Optional legacy alias. If you set it, keep it identical to SECRET_KEY.
JWT_SECRET_KEY=replace-with-the-same-secret-as-secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
MAX_UPLOAD_SIZE_MB=5
LOG_LEVEL=INFO

# Comma-separated list. Example: https://your-app.vercel.app,https://www.your-domain.com
CORS_ORIGINS=https://your-app.vercel.app
ALLOW_CREDENTIALS=false

# MFA
FERNET_KEY=replace-with-a-generated-fernet-key

# GitHub repository scanning
GITHUB_TOKEN=

# AI / LLM
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/auto
LLM_TIMEOUT_SECONDS=120
LLM_TEMPERATURE=0
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=https://your-app.vercel.app
OPENROUTER_SITE_NAME=DristiScan

# Legacy Ollama settings. Leave as-is unless you run Ollama somewhere reachable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-coder
OLLAMA_TIMEOUT_SECONDS=120

# RAG / AI flags
RAG_DEBUG=false
PREWARM_EMBEDDINGS_ON_STARTUP=false
AI_INJECTION_ENABLED=false
AI_SECRETS_ENABLED=false
AI_AUTH_ENABLED=false
AI_DEPENDENCY_ENABLED=false
AI_PLANNER_ENABLED=false
AI_REPORT_ENABLED=true
RAG_TOP_K=5
